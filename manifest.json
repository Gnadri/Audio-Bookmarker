{
  "manifest_version": 3,
  "name": "Audiobook Bookmarker",
  "version": "1.0.0",
  "description": "Manage and update your audiobook links with ease.",
  "permissions": [
    "storage",
    "activeTab",
    "unlimitedStorage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/logo.png",
      "48": "icons/logo.png",
      "128": "icons/logo.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "dashboard.html",
  "icons": {
    "16": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  }
}